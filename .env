# ==================================================
# MYSQL
# ==================================================

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=gantelella
MYSQL_USER=gantelella_user
MYSQL_PASSWORD=gantelella_pass

# ==================================================
# CONTENEDORES
# ==================================================

DB_CONTAINER_NAME=gantelella_db
APP_CONTAINER_NAME=gantelella_app

# ==================================================
# PUERTOS
# ==================================================

MYSQL_PORT=3306
APP_PORT=3000

# ==================================================
# RECURSOS
# ==================================================

DB_MEM_LIMIT=1g
DB_CPUS=1

# ==================================================
# DIRECTORIOS Y ARCHIVOS
# ==================================================

# Archivo SQL inicial
BACKUP_SQL=./backup.sql

# Código fuente de la aplicación
APP_SOURCE_DIR=.

# Directorio persistente de MySQL (opcional si deseas bind mount)
MYSQL_DATA_DIR=./mysql_data

# ==================================================
# APLICACIÓN NODE
# ==================================================

NODE_PORT=3000
MYSQL_HOST=db