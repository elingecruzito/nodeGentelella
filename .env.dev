###########################################################
# VARIABLES DE ENTORNO - DESARROLLO
#
# Este archivo contiene la configuración exclusiva
# para el ambiente de desarrollo.
#
# NO utilizar en producción.
###########################################################

COMPOSE_PROJECT_NAME=gentelella-dev

# ---------------------------------------------------------
# MYSQL
# ---------------------------------------------------------

MYSQL_ROOT_PASSWORD=root_dev
MYSQL_DATABASE=gentelella_dev
MYSQL_USER=gentelella_dev
MYSQL_PASSWORD=gentelella_dev

# ---------------------------------------------------------
# CONTENEDORES
# ---------------------------------------------------------

DB_CONTAINER_NAME=gentelella_db_dev
APP_CONTAINER_NAME=gentelella_app_dev

# ---------------------------------------------------------
# PUERTOS
# ---------------------------------------------------------

MYSQL_PORT=3307
APP_PORT=3001

# ---------------------------------------------------------
# NODE
# ---------------------------------------------------------

NODE_PORT=3000
MYSQL_HOST=db

# ---------------------------------------------------------
# ARCHIVOS
# ---------------------------------------------------------

BACKUP_SQL=./backup.sql
APP_SOURCE_DIR=.

# ---------------------------------------------------------
# NETWORK
# ---------------------------------------------------------

NETWORK_NAME=gentelella_dev_network