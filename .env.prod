###########################################################
# VARIABLES DE ENTORNO - PRODUCCIÓN
#
# Configuración utilizada únicamente en producción.
#
# IMPORTANTE:
# Utilizar contraseñas seguras.
###########################################################

COMPOSE_PROJECT_NAME=gentelella-prod

# ---------------------------------------------------------
# MYSQL
# ---------------------------------------------------------

MYSQL_ROOT_PASSWORD=CAMBIAR_PASSWORD
MYSQL_DATABASE=gentelella_prod
MYSQL_USER=gentelella_prod
MYSQL_PASSWORD=CAMBIAR_PASSWORD

# ---------------------------------------------------------
# CONTENEDORES
# ---------------------------------------------------------

DB_CONTAINER_NAME=gentelella_db_prod
APP_CONTAINER_NAME=gentelella_app_prod

# ---------------------------------------------------------
# PUERTOS
# ---------------------------------------------------------

MYSQL_PORT=3306
APP_PORT=3000

# ---------------------------------------------------------
# NODE
# ---------------------------------------------------------

NODE_PORT=3000
MYSQL_HOST=db

# ---------------------------------------------------------
# ARCHIVOS
# ---------------------------------------------------------

BACKUP_SQL=./backup.sql
APP_SOURCE_DIR=.

# ---------------------------------------------------------
# NETWORK
# ---------------------------------------------------------

NETWORK_NAME=gentelella_prod_network